# Firebase web config — copy to `.env` and fill from the Firebase console
# (Project settings → Your apps → Web app → SDK setup and configuration).
# These VITE_ values are PUBLIC by design (they ship in the browser bundle);
# security is enforced by firestore.rules, not by hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# reCAPTCHA v3 site key for App Check (Firebase console → App Check).
# Public site key; safe to ship. Leave blank for emulator dev.
VITE_RECAPTCHA_SITE_KEY=

# Set to `true` to run against the local Firebase emulators (no real project
# needed). Leave unset/false for the live project.
VITE_USE_EMULATOR=
